# Required environment variables
MONGODB_URI=mongodb://localhost:27017/patient-records   # MongoDB connection string
JWT_ACCESS_SECRET=your-access-secret-here              # Secret for signing access tokens (1 hour)
JWT_REFRESH_SECRET=your-refresh-secret-here            # Secret for signing refresh tokens (7 days)
CLOUDINARY_CLOUD_NAME=your-cloud-name                  # Cloudinary cloud name for file storage
CLOUDINARY_API_KEY=your-api-key                        # Cloudinary API key
CLOUDINARY_API_SECRET=your-api-secret                  # Cloudinary API secret
CLOUDINARY_URL=

# Optional environment variables (shown with their defaults)
# PORT=3000             # defaults to 3000
# NODE_ENV=development  # defaults to development